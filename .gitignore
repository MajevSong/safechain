# Local secrets / env overrides (commit only .env.example)
.env
**/.env

# Editor / OS
.DS_Store
Thumbs.db
*.tmp
_extracted.txt

# Coverage output
chaincode/coverage/
.nyc_output/

# Figure backups
figures/_orig/
